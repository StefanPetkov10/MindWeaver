@using MindWeaver.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.CreateNewFolder" Class="mr-2" />
            New Folder
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="FolderName"
                      Label="Folder name"
                      Variant="Variant.Outlined"
                      Placeholder="e.g. Work, Personal, Ideas…"
                      Immediate="true"
                      @onkeydown="OnKeyDown"
                      AutoFocus="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@string.IsNullOrWhiteSpace(FolderName)"
                   OnClick="Submit">
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    public string FolderName { get; set; } = string.Empty;

    private void Submit()
    {
        if (!string.IsNullOrWhiteSpace(FolderName))
            MudDialog.Close(DialogResult.Ok(FolderName.Trim()));
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")  Submit();
        if (e.Key == "Escape") Cancel();
        await Task.CompletedTask;
    }
}
